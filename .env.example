# Supabase — copy this to .env.local and fill in your values
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — needed only for local migration runner (never expose to browser)
# Found at: Supabase Dashboard → Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App base URL (used for OAuth redirect, magic links)
VITE_APP_URL=http://localhost:5173
